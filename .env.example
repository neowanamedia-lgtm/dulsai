EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ────────────────────────────────────────────────────────────────
# 서버 전용 — 절대 클라이언트(RN) 에 노출 금지.
# EXPO_PUBLIC_ prefix 가 없는 변수는 Expo 가 클라이언트 번들에 포함하지 않는다.
# RESEND_API_KEY 는 (1) Supabase Dashboard 의 SMTP password 필드 또는
#                  (2) Supabase Edge Function 의 secrets 에만 입력한다.
# 이 .env 파일에 직접 두는 건 로컬 dev 도구 (예: 직접 Resend API 호출 스크립트) 용도.
# ────────────────────────────────────────────────────────────────
RESEND_API_KEY=
MAIL_FROM=DulSai <noreply@dulsai.com>

# Google OAuth client IDs (Google Cloud Console → Credentials → OAuth 2.0 client IDs)
# iOS: bundle id 기준 (com.dulsai.app 등)
# Android: package name + SHA1 기준
# Web: Supabase 가 사용하는 redirect 가 들어있는 web client id (Supabase Dashboard Google provider 의 Client ID 와 동일)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
